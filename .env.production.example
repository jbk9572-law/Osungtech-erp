# 오라클 서버에서 이 파일을 복사해 .env.production으로 저장하고 실제 값을 채운다.
# (Supabase 대시보드 > Project Settings > API 에서 그대로 복사)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxx

# 관리자가 새 계정을 만들 때만 필요 (환경설정 > 권한관리). Supabase 대시보드 >
# Project Settings > API > service_role 에서 복사. 서버에서만 쓰이며 절대
# 브라우저로 노출되지 않는다.
SUPABASE_SERVICE_ROLE_KEY=xxxxx

# DuckDNS 등에서 발급받은 도메인 (예: osungtech-erp.duckdns.org)
SITE_DOMAIN=your-subdomain.duckdns.org
